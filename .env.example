# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Public gallery URL for share links / QR codes
VITE_PUBLIC_SITE_URL=

# Google Drive — required for "Save to Google Drive" in gallery download modal
# 1. https://console.cloud.google.com → APIs → enable "Google Drive API"
# 2. OAuth consent screen → User type: External → Publishing status: Testing
# 3. OAuth consent screen → Test users → add every Google account that will sign in
#    (otherwise users see "Google hasn't verified this app" and must click Continue)
# 4. Credentials → Create OAuth client ID → Web application
# 5. Authorized JavaScript origins: http://localhost:5173 and your production URL
# 6. Paste the Client ID below, restart npm run dev
VITE_GOOGLE_CLIENT_ID=
