# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Public gallery URL for share links / QR codes
VITE_PUBLIC_SITE_URL=

# Google Drive — optional; "Save to Google Drive" in the gallery download modal
# Local download works for all visitors without Google.
#
# 1. https://console.cloud.google.com → APIs → enable "Google Drive API"
# 2. OAuth consent screen → User type: External
# 3. Credentials → OAuth client ID → Web application
#    Authorized JavaScript origins: http://localhost:5173 and your production URL
# 4. For ALL Google accounts (not just test users):
#    OAuth consent screen → Publish app → set Publishing status to "In production"
#    (Testing mode only allows emails listed under Test users — others get Error 403 access_denied)
# 5. drive.file scope may require Google verification after publishing; until then visitors
#    can still download via "Save to this device" (Local).
# 6. Paste the Client ID below, restart npm run dev
VITE_GOOGLE_CLIENT_ID=
