{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/m/:slug/manifest.json", "destination": "/api/m/:slug/manifest" },
    { "source": "/m/:slug/apple-touch-icon.png", "destination": "/api/m/:slug/icon" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
